{
  "openapi": "3.0.3",
  "info": {
    "title": "Workhorse API",
    "version": "0.1.0",
    "description": "Local-first runtime API for the Workhorse multi-workspace kanban."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3484"
    }
  ],
  "tags": [
    {
      "name": "Runtime"
    },
    {
      "name": "Workspaces"
    },
    {
      "name": "Tasks"
    },
    {
      "name": "Runs"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "health",
        "summary": "Read runtime health",
        "tags": [
          "Runtime"
        ],
        "responses": {
          "200": {
            "description": "Runtime health information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/workspaces": {
      "get": {
        "operationId": "listWorkspaces",
        "summary": "List registered workspaces",
        "tags": [
          "Workspaces"
        ],
        "responses": {
          "200": {
            "description": "Workspace collection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkspacesResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createWorkspace",
        "summary": "Register a workspace",
        "tags": [
          "Workspaces"
        ],
        "responses": {
          "201": {
            "description": "Created workspace",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkspaceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWorkspaceBody"
              }
            }
          }
        }
      }
    },
    "/api/workspaces/{workspaceId}": {
      "patch": {
        "operationId": "updateWorkspace",
        "summary": "Rename a workspace",
        "tags": [
          "Workspaces"
        ],
        "responses": {
          "200": {
            "description": "Updated workspace",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkspaceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "workspaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateWorkspaceBody"
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteWorkspace",
        "summary": "Delete a workspace",
        "tags": [
          "Workspaces"
        ],
        "responses": {
          "200": {
            "description": "Deleted workspace id",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteWorkspaceResponse"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "workspaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/api/workspaces/{workspaceId}/git/refs": {
      "get": {
        "operationId": "listWorkspaceGitRefs",
        "summary": "List Git refs for a workspace",
        "tags": [
          "Workspaces"
        ],
        "responses": {
          "200": {
            "description": "Workspace Git refs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkspaceGitRefsResponse"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "workspaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/api/tasks": {
      "get": {
        "operationId": "listTasks",
        "summary": "List tasks across workspaces",
        "tags": [
          "Tasks"
        ],
        "responses": {
          "200": {
            "description": "Task collection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TasksResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "workspaceId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ]
      },
      "post": {
        "operationId": "createTask",
        "summary": "Create a task card",
        "tags": [
          "Tasks"
        ],
        "responses": {
          "201": {
            "description": "Created task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskBody"
              }
            }
          }
        }
      }
    },
    "/api/tasks/{taskId}": {
      "patch": {
        "operationId": "updateTask",
        "summary": "Update a task card",
        "tags": [
          "Tasks"
        ],
        "responses": {
          "200": {
            "description": "Updated task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTaskBody"
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteTask",
        "summary": "Delete a task card",
        "tags": [
          "Tasks"
        ],
        "responses": {
          "200": {
            "description": "Deleted task id",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteTaskResponse"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/api/tasks/{taskId}/worktree/cleanup": {
      "post": {
        "operationId": "cleanupTaskWorktree",
        "summary": "Cleanup a task worktree",
        "tags": [
          "Tasks"
        ],
        "responses": {
          "200": {
            "description": "Cleaned up task worktree",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CleanupTaskWorktreeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Unable to cleanup task worktree",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/api/tasks/{taskId}/start": {
      "post": {
        "operationId": "startTask",
        "summary": "Start task execution",
        "tags": [
          "Runs"
        ],
        "responses": {
          "200": {
            "description": "Started run",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartTaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Unable to start task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/api/tasks/{taskId}/stop": {
      "post": {
        "operationId": "stopTask",
        "summary": "Stop task execution",
        "tags": [
          "Runs"
        ],
        "responses": {
          "200": {
            "description": "Stopped run",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StopTaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Unable to stop task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/api/tasks/{taskId}/plan": {
      "post": {
        "operationId": "planTask",
        "summary": "Create a task plan and move it to todo",
        "tags": [
          "Tasks"
        ],
        "responses": {
          "200": {
            "description": "Planned task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlanTaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Unable to plan task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/api/tasks/{taskId}/runs": {
      "get": {
        "operationId": "listRuns",
        "summary": "List task runs",
        "tags": [
          "Runs"
        ],
        "responses": {
          "200": {
            "description": "Run collection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunsResponse"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/api/runs/{runId}/log": {
      "get": {
        "operationId": "getRunLog",
        "summary": "Read a stored run log",
        "tags": [
          "Runs"
        ],
        "responses": {
          "200": {
            "description": "Run log content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunLogResponse"
                }
              }
            }
          },
          "404": {
            "description": "Run not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "runId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ApiError": {
        "type": "object",
        "properties": {
          "ok": {
            "enum": [
              false
            ]
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "details": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/ApiErrorIssue"
                    }
                  }
                ]
              }
            },
            "required": [
              "code",
              "message"
            ]
          }
        },
        "required": [
          "ok",
          "error"
        ]
      },
      "ApiErrorIssue": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "expected": {
            "type": "string"
          },
          "value": {}
        },
        "required": [
          "path",
          "expected",
          "value"
        ]
      },
      "Workspace": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "rootPath": {
            "type": "string"
          },
          "isGitRepo": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "rootPath",
          "isGitRepo",
          "createdAt",
          "updatedAt"
        ]
      },
      "WorkspaceGitRef": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "kind": {
            "$ref": "#/components/schemas/WorkspaceGitRefKind"
          },
          "isDefault": {
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "kind",
          "isDefault"
        ]
      },
      "WorkspaceGitRefKind": {
        "oneOf": [
          {
            "enum": [
              "remote"
            ]
          },
          {
            "enum": [
              "local"
            ]
          }
        ]
      },
      "TaskWorktree": {
        "type": "object",
        "properties": {
          "baseRef": {
            "type": "string"
          },
          "branchName": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/TaskWorktreeStatus"
          },
          "cleanupReason": {
            "type": "string"
          },
          "lastSyncedBaseAt": {
            "type": "string"
          }
        },
        "required": [
          "baseRef",
          "branchName",
          "status"
        ]
      },
      "TaskWorktreeStatus": {
        "oneOf": [
          {
            "enum": [
              "not_created"
            ]
          },
          {
            "enum": [
              "ready"
            ]
          },
          {
            "enum": [
              "cleanup_pending"
            ]
          },
          {
            "enum": [
              "removed"
            ]
          }
        ]
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "workspaceId": {
            "type": "string"
          },
          "column": {
            "$ref": "#/components/schemas/TaskColumn"
          },
          "order": {
            "type": "number"
          },
          "runnerType": {
            "$ref": "#/components/schemas/RunnerType"
          },
          "runnerConfig": {
            "$ref": "#/components/schemas/RunnerConfig"
          },
          "worktree": {
            "$ref": "#/components/schemas/TaskWorktree"
          },
          "lastRunId": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "description",
          "workspaceId",
          "column",
          "order",
          "runnerType",
          "runnerConfig",
          "worktree",
          "createdAt",
          "updatedAt"
        ]
      },
      "TaskColumn": {
        "oneOf": [
          {
            "enum": [
              "backlog"
            ]
          },
          {
            "enum": [
              "todo"
            ]
          },
          {
            "enum": [
              "running"
            ]
          },
          {
            "enum": [
              "review"
            ]
          },
          {
            "enum": [
              "done"
            ]
          },
          {
            "enum": [
              "archived"
            ]
          }
        ]
      },
      "RunnerType": {
        "oneOf": [
          {
            "enum": [
              "codex"
            ]
          },
          {
            "enum": [
              "shell"
            ]
          }
        ]
      },
      "RunnerConfig": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/ShellRunnerConfig"
          },
          {
            "$ref": "#/components/schemas/CodexRunnerConfig"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "shell": "#/components/schemas/ShellRunnerConfig",
            "codex": "#/components/schemas/CodexRunnerConfig"
          }
        }
      },
      "ShellRunnerConfig": {
        "type": "object",
        "properties": {
          "type": {
            "enum": [
              "shell"
            ]
          },
          "command": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "command"
        ]
      },
      "CodexRunnerConfig": {
        "type": "object",
        "properties": {
          "type": {
            "enum": [
              "codex"
            ]
          },
          "prompt": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "approvalMode": {
            "oneOf": [
              {
                "enum": [
                  "default"
                ]
              },
              {
                "enum": [
                  "auto"
                ]
              }
            ]
          }
        },
        "required": [
          "type",
          "prompt"
        ]
      },
      "Run": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "taskId": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/RunStatus"
          },
          "runnerType": {
            "$ref": "#/components/schemas/RunnerType"
          },
          "command": {
            "type": "string"
          },
          "pid": {
            "type": "number"
          },
          "exitCode": {
            "type": "number"
          },
          "startedAt": {
            "type": "string"
          },
          "endedAt": {
            "type": "string"
          },
          "logFile": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/components/schemas/Recordstringstring"
          }
        },
        "required": [
          "id",
          "taskId",
          "status",
          "runnerType",
          "command",
          "startedAt",
          "logFile"
        ]
      },
      "RunStatus": {
        "oneOf": [
          {
            "enum": [
              "running"
            ]
          },
          {
            "enum": [
              "queued"
            ]
          },
          {
            "enum": [
              "succeeded"
            ]
          },
          {
            "enum": [
              "failed"
            ]
          },
          {
            "enum": [
              "interrupted"
            ]
          },
          {
            "enum": [
              "canceled"
            ]
          }
        ]
      },
      "Recordstringstring": {
        "type": "object",
        "properties": {},
        "required": [],
        "description": "Construct a type with a set of properties K of type T",
        "additionalProperties": {
          "type": "string"
        }
      },
      "CreateWorkspaceBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "rootPath": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "rootPath"
        ]
      },
      "ListWorkspaceGitRefsParams": {
        "type": "object",
        "properties": {
          "workspaceId": {
            "type": "string"
          }
        },
        "required": [
          "workspaceId"
        ]
      },
      "UpdateWorkspaceBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": []
