{
  "name": "@workhorse/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "predev": "npm run build --workspace @workhorse/contracts",
    "prestart": "npm run build --workspace @workhorse/contracts",
    "pretest": "npm run build --workspace @workhorse/contracts",
    "build": "tsc -p tsconfig.json",
    "dev": "WORKHORSE_DEV_SERVER=1 tsx watch --exclude ../web/node_modules/.vite-temp --exclude ../web/dist src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@workhorse/contracts": "0.1.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "vite": "^8.0.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.10"
  }
}
